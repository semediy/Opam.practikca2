<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:resources="clr-namespace:Logistics.Resources"
             x:Class="Logistics.Views.LogistHomePage.DriversPage">

    <StackPanel Margin="20" Spacing="12">

        <TextBox Width="260" Watermark="Пошук водія" Padding="8"/>

        <Border CornerRadius="12" Padding="12">

            <StackPanel>

                <Grid ColumnDefinitions="3*,2*,2*,2*,1*,1*">
                    <TextBlock Text="ПІБ" FontWeight="Bold"/>
                    <TextBlock Grid.Column="4" Text="✔" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="❌" HorizontalAlignment="Center"/>
                </Grid>

                <Border Height="1" Background="#ccc" Margin="0,5"/>

                <ItemsControl ItemsSource="{Binding Drivers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <resources:StatusRow/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>