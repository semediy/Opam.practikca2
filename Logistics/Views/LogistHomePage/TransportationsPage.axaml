<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:resources="clr-namespace:Logistics.Resources"
             x:Class="Logistics.Views.LogistHomePage.TransportationsPage">

    <StackPanel Margin="20" Spacing="12">

        <TextBox Width="260" Watermark="Пошук (адреса / вантаж)" Padding="8"/>

        <Border CornerRadius="12" Padding="12">

            <StackPanel>

                <Grid ColumnDefinitions="3*,2*,2*,2*,1*,1*">
                    <TextBlock Text="Маршрут" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Вантаж"/>
                    <TextBlock Grid.Column="2" Text="Дата"/>
                    <TextBlock Grid.Column="3" Text="Водій"/>
                    <TextBlock Grid.Column="4" Text="✔" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="❌" HorizontalAlignment="Center"/>
                </Grid>

                <Border Height="1" Background="#ccc" Margin="0,5"/>

                <ItemsControl ItemsSource="{Binding Transportations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <resources:StatusRow/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>